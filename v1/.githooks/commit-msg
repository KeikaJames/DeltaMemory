#!/usr/bin/env bash
set -u

message_file="${1:-}"
if [[ -z "$message_file" ]]; then
  echo "ERROR: commit message file path is required." >&2
  exit 2
fi

if [[ ! -f "$message_file" ]]; then
  echo "ERROR: commit message file not found: $message_file" >&2
  exit 2
fi

if grep -Eq '^Co-authored-by:[[:space:]]*(Copilot|copilot|GitHub Copilot)' "$message_file"; then
  cat >&2 <<'MSG'
ERROR: Commit message contains a forbidden Copilot co-author trailer.
Remove any "Co-authored-by: Copilot" or "Co-authored-by: GitHub Copilot" line and commit again.

Bypass is possible with git commit --no-verify, but it is strongly discouraged.
MSG
  exit 1
fi

exit 0
