  "bank_off_byte_equal": {
    "n_prompts": 1000,
    "mismatches_max": 0,
    "use_identical_forward_path_required": true
  },

  "adversarial_budget": {
    "fact_selection": "top_100_by_delta_norm_F",
    "ppl_drift_pct_max": 20.0,
    "gating": "reported_only_not_gating"
  },

  "latency_profile": {
    "k_values": [0, 10, 100, 1000, 10000],
    "no_threshold": true,
    "dtype": "bf16_sync"
  },

  "falsification_tost": {
    "claim": "bank composable to N=10000 without meaningful capability damage",
    "tost_bounds_pct": [-8.0, 8.0],
    "tost_alpha": 0.05,
    "metric": "WikiText103_relative_ppl_drift_at_k1000",
    "bayes_factor_prior": "flat over [-30%, 30%]",
    "bayes_factor_min": 3.0
  },

  "f_audits": {
    "F1_subsets_deterministic_seed0_reported_before_results": true,
    "F2_patched_fact_set_random_not_solo_pass_filtered": true,
    "F3_bank_on_k0_uses_identical_forward_path_as_base": true,
    "F4_report_per_task_per_seed_std_and_worst_k": true,
    "F5_latency_bf16_sync_identical_to_other_phases": true,
    "F6_forgetting_probes_locked_in_this_preregister": true,
    "F7_lm_eval_version_sha_pinned": true
  },

  "decision_rule": "ALL of lm_eval thresholds, wikitext_103 thresholds, catastrophic_forgetting, bank_off_byte_equal, AND falsification_tost (TOST passes at alpha=0.05 AND BF>=3) must PASS for PUBLISHABLE POSITIVE. Adversarial budget is reported but does not gate. Any FAIL of a gating component => HEADLINE CLAIM FALSIFIED."
