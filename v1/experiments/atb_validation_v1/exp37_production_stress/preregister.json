{
  "experiment": "exp37_production_stress",
  "version": 1,
  "commit_locked": false,
  "depends_on": ["exp35b_memit_bank/bank.pt", "exp36_binding_audit POSITIVE"],
  "model": "Qwen/Qwen3-4B-Instruct-2507",
  "device": "mps",
  "dtype": "bf16",

  "lm_eval": {
    "framework": "lm-evaluation-harness",
    "pin_version_sha_required": true,
    "tasks": [
      {"name": "mmlu_stem_subset", "n_items": 500, "seed_for_subset": 0},
      {"name": "hellaswag", "n_items": 500, "seed_for_subset": 0},
      {"name": "arc_easy", "n_items": 500, "seed_for_subset": 0},
      {"name": "triviaqa", "n_items": 500, "seed_for_subset": 0}
    ],
    "k_values": [0, 10, 100, 1000, 10000],
    "patched_facts_seed": 0,
    "relative_drop_per_task_max_at_k1000_pct": 5.0,
    "relative_drop_per_task_max_at_k10000_pct": 12.0
  },

  "wikitext_103": {
    "n_validation_tokens": 50000,
    "ppl_drift_pct_max_at_k10": 3.0,
    "ppl_drift_pct_max_at_k100": 8.0,
    "ppl_drift_pct_max_at_k1000": 15.0,
    "ppl_drift_pct_max_at_k10000": 25.0
  },

  "catastrophic_forgetting": {
    "n_facts_pre_registered_in_this_file": 50,
    "facts_must_not_be_in_bank": true,
    "delta_margin_within_1nat_pass_frac_min": 0.95,
    "facts": [
      "The capital of France is Paris.",
      "The capital of Japan is Tokyo.",
      "The capital of Germany is Berlin.",
      "Water boils at 100 degrees Celsius.",
      "The Sun is a star.",
      "Mount Everest is in the Himalayas.",
